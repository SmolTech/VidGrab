# Gradle files
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# Local configuration file (sdk path, etc)
local.properties

# Log/OS files
*.log
.DS_Store

# Android Studio / IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
.navigation/
captures/
output.json

# Keystore files (do not commit signing keys)
*.jks
*.keystore

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Google Services (e.g. APIs or Firebase)
google-services.json

# Version control
vcs.xml

# Kotlin
.kotlin/

# Chaquopy / Python build intermediates
app/build/python/
*.pyc
__pycache__/
